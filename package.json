{
  "name": "chromatic-tuner",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/dev.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:css": "stylelint \"public/**/*.css\"",
    "lint:css:fix": "stylelint \"public/**/*.css\" --fix",
    "lint:css:strict": "stylelint \"public/**/*.css\" --max-warnings=0",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test tests/ui.spec.ts --project=chromium --project=\"Mobile Safari\"",
    "test:unit": "vitest run",
    "test": "npm run typecheck && npm run test:unit && npm run test:e2e",
    "ci": "npm run build && npm test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/audioworklet": "^0.0.94",
    "@types/node": "^25.2.3",
    "chokidar": "^5.0.0",
    "esbuild": "^0.27.2",
    "jsdom": "^28.1.0",
    "postcss-safe-parser": "^7.0.1",
    "stylelint": "^17.3.0",
    "stylelint-order": "^7.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
